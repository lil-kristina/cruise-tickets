spring.datasource.url=jdbc:postgresql://localhost:5432/ИМЯ_ТВОЕЙ_БД
spring.datasource.username=ТВОЙ_ЮЗЕР
spring.datasource.password=ТВОЙ_ПАРОЛЬ
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

server.port=8080

app.jwt.secret=СЮДА_ДЛИННУЮ_СТРОКУ_НЕ_МЕНЕЕ_32_СИМВОЛОВ
app.jwt.expiration=86400000

app.cors.allowed-origins=http://localhost:5500,http://127.0.0.1:5500